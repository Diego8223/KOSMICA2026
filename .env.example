# ============================================================
#  Kosmica - Variables de Entorno
#  Copia como: .env  (NUNCA subas .env a GitHub)
#  Para el BACKEND copia en Render → Environment Variables
#  Para el FRONTEND copia en Render → Environment Variables
# ============================================================

# ════════════════════════════════════════════════════════════
#  FRONTEND (prefix REACT_APP_)
# ════════════════════════════════════════════════════════════

# URL del backend (Render service URL)
REACT_APP_API_URL=https://kosmica-backend.onrender.com

# IA Chatbot (Isabel) — https://console.anthropic.com
REACT_APP_ANTHROPIC_KEY=sk-ant-api03-REEMPLAZA

# Clave pública VAPID para notificaciones push (ver abajo)
REACT_APP_VAPID_PUBLIC_KEY=REEMPLAZA-CON-TU-VAPID-PUBLIC-KEY

# MercadoPago public key (para el frontend)
REACT_APP_MP_PUBLIC_KEY=TEST-REEMPLAZA

# Contraseña del panel admin
REACT_APP_ADMIN_PASSWORD=Kosmica2025

# ════════════════════════════════════════════════════════════
#  BACKEND (Spring Boot — Render Environment Variables)
# ════════════════════════════════════════════════════════════

# Base de datos PostgreSQL (Render la provee automáticamente)
SPRING_DATASOURCE_URL=jdbc:postgresql://HOST:5432/DBNAME
SPRING_DATASOURCE_USERNAME=USER
SPRING_DATASOURCE_PASSWORD=PASS

# MercadoPago — https://www.mercadopago.com.co/developers/panel
MERCADOPAGO_ACCESS_TOKEN=TEST-REEMPLAZA-CON-TU-ACCESS-TOKEN
MERCADOPAGO_PUBLIC_KEY=TEST-REEMPLAZA-CON-TU-PUBLIC-KEY

# Tienda
STORE_URL=https://www.kosmica.com.co
STORE_NAME=Kosmica
STORE_EMAIL=hola@kosmica.com.co

# Email SendGrid (gratis 100/día) — https://sendgrid.com
SENDGRID_API_KEY=SG.REEMPLAZA-CON-TU-CLAVE

# ── WhatsApp (notificaciones al admin y cliente) ──────────
# Tu número de WhatsApp con código de país (sin + ni espacios)
# ej: 573043927148
ADMIN_WHATSAPP=573043927148
# Clave CallMeBot — gratis en: https://www.callmebot.com/blog/free-api-whatsapp-messages/
# Pasos: 1) Agrega +34 644 27 69 05 a tus contactos
#        2) Envía: "I allow callmebot to send me messages"
#        3) Recibes tu apikey por WhatsApp
CALLMEBOT_API_KEY=REEMPLAZA-CON-TU-APIKEY

# ── Push Notifications (VAPID) ────────────────────────────
# Genera tu par de claves VAPID con:
#   npx web-push generate-vapid-keys
# Pega AQUÍ las dos claves que genera:
VAPID_PUBLIC_KEY=REEMPLAZA-CON-TU-VAPID-PUBLIC-KEY
VAPID_PRIVATE_KEY=REEMPLAZA-CON-TU-VAPID-PRIVATE-KEY

# ── Groq AI (opcional) ────────────────────────────────────
GROQ_API_KEY=gsk_REEMPLAZA

# ── Cloudinary (para subir imágenes) ─────────────────────
# https://cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=tu-cloud-name
CLOUDINARY_API_KEY=tu-api-key
CLOUDINARY_API_SECRET=tu-api-secret

SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxx
EMAIL_FROM=tuemail@tudominio.com

# ===== DATABASE (SUPABASE) =====
SPRING_DATASOURCE_URL=jdbc:postgresql://db.kibhvbuwpwnufszmgeju.supabase.co:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=Kosmica2025

# ===== JPA =====
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true