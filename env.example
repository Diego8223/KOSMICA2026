# ============================================================
#  Kosmica — Variables de Entorno
#  Copia como: .env  (NUNCA subas .env a GitHub)
#  Para Render: configura cada variable en Environment Variables
# ============================================================

# ════════════════════════════════════════════════════════════
#  BASE DE DATOS (PostgreSQL local con Docker)
# ════════════════════════════════════════════════════════════
POSTGRES_DB=luxshop
POSTGRES_USER=luxshop_user
# ✅ Generar con: openssl rand -hex 16
POSTGRES_PASSWORD=REEMPLAZA-CON-PASSWORD-SEGURA

# ════════════════════════════════════════════════════════════
#  pgAdmin4
# ════════════════════════════════════════════════════════════
PGADMIN_EMAIL=admin@kosmica.com
# ✅ Generar con: openssl rand -hex 12
PGADMIN_PASSWORD=REEMPLAZA-CON-PASSWORD-SEGURA

# ════════════════════════════════════════════════════════════
#  BACKEND (Spring Boot)
# ════════════════════════════════════════════════════════════

# Tienda
STORE_URL=https://www.kosmica.com.co
STORE_NAME=Kosmica
STORE_EMAIL=hola@kosmica.com.co

# JWT — ✅ OBLIGATORIO. Generar con: openssl rand -base64 64
JWT_SECRET=REEMPLAZA-CON-CLAVE-GENERADA-CON-OPENSSL
JWT_EXPIRATION=86400000

# Admin — ✅ OBLIGATORIO. Generar con: openssl rand -hex 32
ADMIN_API_KEY=REEMPLAZA-CON-CLAVE-GENERADA-CON-OPENSSL

# ── MercadoPago ─────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=TEST-REEMPLAZA
MERCADOPAGO_PUBLIC_KEY=TEST-REEMPLAZA
REACT_APP_MP_PUBLIC_KEY=TEST-REEMPLAZA

# ── Wompi (Bancolombia) ─────────────────────────────────────
WOMPI_PUBLIC_KEY=pub_prod_REEMPLAZA
WOMPI_PRIVATE_KEY=prv_prod_REEMPLAZA
WOMPI_EVENTS_SECRET=prod_events_REEMPLAZA
# ✅ FIX: esta clave es OBLIGATORIA para que el checkout funcione
WOMPI_INTEGRITY_SECRET=prod_integrity_REEMPLAZA

# ── Email ───────────────────────────────────────────────────
MAIL_USER=tuemail@tudominio.com
MAIL_PASSWORD=REEMPLAZA
SENDGRID_API_KEY=SG.REEMPLAZA

# ── Cloudinary (imágenes) ───────────────────────────────────
# Formato: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=cloudinary://REEMPLAZA:REEMPLAZA@REEMPLAZA

# ── Push Notifications (VAPID) ─────────────────────────────
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=REEMPLAZA
VAPID_PRIVATE_KEY=REEMPLAZA
REACT_APP_VAPID_PUBLIC_KEY=REEMPLAZA

# ── WhatsApp / CallMeBot ────────────────────────────────────
ADMIN_WHATSAPP=573043927148
CALLMEBOT_API_KEY=REEMPLAZA

# ── Groq AI ─────────────────────────────────────────────────
GROQ_API_KEY=gsk_REEMPLAZA

# ── Anthropic (chatbot Isabel — ahora en el BACKEND) ────────
# ✅ FIX: esta clave ya NO va en el frontend — solo en el backend
ANTHROPIC_API_KEY=sk-ant-api03-REEMPLAZA

# ════════════════════════════════════════════════════════════
#  FRONTEND (React)
# ════════════════════════════════════════════════════════════
# URL del backend
REACT_APP_API_URL=https://kosmica-backend.onrender.com

# Contraseña del panel admin
REACT_APP_ADMIN_PASSWORD=REEMPLAZA-CON-PASSWORD-SEGURA
# ✅ REACT_APP_ANTHROPIC_KEY eliminada — el chatbot ahora pasa por el backend
